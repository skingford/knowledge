{
  "devDependencies": {
    "mermaid": "^11.13.0",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitepress-plugin-tabs": "^0.8.0"
  },
  "scripts": {
    "docs:dev": "vitepress dev docs --host 0.0.0.0",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:check:vocabulary": "node scripts/check-vocabulary-phonetics.mjs",
    "docs:fix:links": "node scripts/normalize-doc-links.mjs",
    "docs:check:links": "node scripts/normalize-doc-links.mjs --check",
    "docs:check": "npm run docs:check:vocabulary && npm run docs:check:links && npm run docs:build"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
